# =============================================================================
# openclaw-config — copy to .env and fill in.
# Never commit .env. Rotate any secret you accidentally paste into chat.
# =============================================================================

# ----- Tailscale ------------------------------------------------------------
# Generate at https://login.tailscale.com/admin/settings/keys (reusable, ephemeral OK).
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
# Hostname your machine will appear as on the tailnet.
TS_HOSTNAME=openclaw

# ----- Discord --------------------------------------------------------------
# Create at https://discord.com/developers/applications → Bot → Reset Token.
# Required intents: Message Content, Direct Messages.
DISCORD_BOT_TOKEN=
# Your numeric Discord user ID (Settings → Advanced → Developer Mode → right-click your name).
# Only this user can DM the bot (allowlist).
DISCORD_OWNER_ID=

# ----- RunPod serverless LLM ------------------------------------------------
# Full base URL of your RunPod serverless OpenAI-compatible endpoint.
# Format: https://api.runpod.ai/v2/<endpoint-id>/openai/v1
RUNPOD_BASE_URL=https://api.runpod.ai/v2/REPLACE_ME/openai/v1
RUNPOD_API_KEY=
# Model name as exposed by your endpoint (e.g. qwen/qwen3-32b, google/gemma-3-27b-it).
RUNPOD_MODEL=qwen/qwen3-32b

# ----- Blog repo (for opening PRs with new posts) ---------------------------
# owner/repo of the private repo backing your blog.
BLOG_REPO=youruser/yourblog
BLOG_DEFAULT_BRANCH=main
# Path inside the repo where new markdown posts should land.
BLOG_POSTS_DIR=src/content/posts
# GitHub PAT with `repo` scope (fine-grained: contents=write, pull_requests=write).
GITHUB_TOKEN=

# ----- Brand (used in prompt templates) -------------------------------------
# Keep these out of the public repo — they're loaded at runtime from .env.
BRAND_NAME=YourBrand
BRAND_URL=https://example.com
BRAND_TAGLINE=One-sentence description of what your blog is about.
# A short paragraph describing your writing voice (technical, casual, dry, etc.).
BRAND_VOICE=Direct, technical, no hype. Show the command, show the output.

# ----- ElevenLabs (optional, for short-form voiceovers) ---------------------
# Leave blank to skip voiceover synthesis; the bot will still return a script.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ----- Reddit recommendation allowlist --------------------------------------
# Comma-separated subreddits the bot is allowed to recommend posting to.
# The bot will pick the best fit for the post and draft a value-first self-post
# (no link drop). Posting itself remains manual.
REDDIT_ALLOWED_SUBS=LocalLLaMA,MachineLearning,homelab
